# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Drive OAuth
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=

# Source root: existing ebooks root (domain/PDF and domain/Doc)
GDRIVE_SOURCE_ROOT_ID=

# Destination root: output root (same structure; folders created as needed)
GDRIVE_DEST_ROOT_ID=

# Parallel book workers
CONCURRENCY=2

# Optional: system Chrome/Chromium if bundled Puppeteer fails
# PUPPETEER_EXECUTABLE_PATH=
