OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PUPPETEER_EXECUTABLE_PATH=
PORT=4000
MAX_CONCURRENT_SESSIONS=3
SESSION_TTL_MS=1800000

# --- Two-phase ingest ---
# Phase 1 (CLI: --phase normalize): no AI. Drops signature, declaration, approval,
# acknowledgements, abstract, list of figures/tables, TOC-only blocks, executive summary (strict).
INGEST_BASELINE_STRIP_MODE=strict

# Phase 2 (CLI: --phase enhance --from-md ... --manifest ... [--polish] [--page-fit])
INGEST_EQUATIONS=1
INGEST_STRICT_SOURCE_FIDELITY=0
INGEST_REWRITE_QUALITY_GATE=0
INGEST_PREMIUM_FULL=0
INGEST_TABLE_RECONSTRUCTION=confidence
INGEST_TARGET_PAGES=250
INGEST_WORDS_PER_PAGE=275
INGEST_PAGE_FIT_TOLERANCE=0.12
INGEST_MAX_EXPAND_RATIO=2
INGEST_SOURCE_PAGES=
INGEST_PAGE_FIT_MEASURED_SECOND_PASS=1

# Optional: better Word math → Markdown when pandoc is on PATH
# INGEST_DOCX_MATH=pandoc

# Batch / Drive (only if you use batch upload)
# BATCH_MAX_RETRY_ROUNDS=5
# GDRIVE_CLIENT_ID=
# GDRIVE_EBOOKS_ROOT_ID=
