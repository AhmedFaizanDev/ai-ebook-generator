OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Default output language (en | fr | de | hi; aliases: english, french, deutsch, german, hin, hindi). Batch CSV/XLSX optional column `language` (or lang / output_language) overrides per row.
OUTPUT_LANGUAGE=en

PUPPETEER_EXECUTABLE_PATH=
MAX_CONCURRENT_SESSIONS=3
SESSION_TTL_MS=1800000

DEBUG_ORCHESTRATOR=0
DEBUG_MODE=false
LLM_CONCURRENCY=3

LIGHT_MODEL=gpt-4o-mini
PORT=4000
# Batch CLI: automatic retry rounds for failed books (same run, no re-login)
BATCH_MAX_RETRY_ROUNDS=5
BATCH_COOLDOWN_BETWEEN_ROUNDS_MS=30000
# Duplicate prevention: skip generation if PDF+DOCX already exist in Drive (default: true)
BATCH_SKIP_IF_IN_DRIVE=true
# When uploading, update existing file by name instead of creating a duplicate (default: true). Set to false to always create new files.
BATCH_UPDATE_IF_EXISTS=true
# Drive upload resilience (optional): extra retries and backoff for rate limits / network blips
# DRIVE_UPLOAD_MAX_RETRIES=5
# DRIVE_UPLOAD_BASE_DELAY_MS=3000
# Batch CLI: when unset/false, PDF export tolerates invalid Mermaid (hides broken diagrams). Set to true to fail the book on any diagram error (matches API default strictMode).
# BATCH_STRICT_EXPORT=true

# Google Drive OAuth (for batch upload)
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=

GDRIVE_REFRESH_TOKEN=

# Domain-based: root folder ID; batch resolves root/<domain>/PDF and root/<domain>/Doc
GDRIVE_EBOOKS_ROOT_ID=<folder id of ebooks root>

# Legacy (single folder): use when not using domain-based
# GDRIVE_PDF_FOLDER_ID=
# GDRIVE_DOC_FOLDER_ID=
