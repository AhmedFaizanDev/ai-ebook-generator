    "batch-status": "tsx src/cli/batch-status.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "googleapis": "^171.4.0",
    "highlight.js": "^11.11.1",
    "html-to-docx": "^1.8.0",
    "katex": "^0.16.45",
    "mammoth": "^1.12.0",
